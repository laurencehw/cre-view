# =============================================================================
# CRE View — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# ─── Computer Vision ──────────────────────────────────────────────────────────
# Choose ONE provider and fill in the corresponding variables.
VISION_PROVIDER=mock

# Option O: OpenAI (GPT-4o Vision)
OPENAI_API_KEY=your_openai_api_key_here

# Option A: Azure Computer Vision
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your_azure_vision_key_here

# Option B: Google Cloud Vision
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option C: AWS Rekognition
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ─── Supabase (recommended) ──────────────────────────────────────────────────
# Set these to enable Supabase Auth, Database, and Storage.
# When set, the app uses Supabase instead of custom JWT auth and local storage.
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Database ─────────────────────────────────────────────────────────────────
# When using Supabase, set this to your Supabase Postgres connection string:
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/creview
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creview
DB_USER=postgres
DB_PASSWORD=password

# ─── Geolocation / Maps ───────────────────────────────────────────────────────
MAPBOX_SECRET_TOKEN=your_mapbox_secret_token_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── CRE Data Sources ─────────────────────────────────────────────────────────
# e.g. CoStar, REIS, CompStak
CRE_DATA_API_KEY=your_cre_data_api_key_here
CRE_DATA_BASE_URL=https://api.costar.com/v1

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
CORS_ORIGIN=http://localhost:3000

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
